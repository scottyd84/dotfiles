# Personal shell aliases & functions — single source of truth.
# Sourced by zsh (~/.zshrc) and bash (~/.bashrc). Reload in place with: rz
# Keep this file portable (plain aliases / POSIX funcs) so bash can source it too.

# --- reload / git ---
reloadzsh() { source "$HOME/.zshrc.local"; }
alias rz='reloadzsh'
alias gs='git status'

# --- system / misc ---
alias c='clear'
alias update='sudo apt update && sudo apt upgrade -y'
alias myip='curl ifconfig.me; echo'
alias nvim-venv='source ~/.virtualenvs/neovim/bin/activate'
alias nv='nvim .'

# --- ls / grep (identical in both shells) ---
alias ll='ls -alFh'
alias la='ls -A'
alias l='ls -CF'
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias fgrep='fgrep --color=auto'
alias egrep='egrep --color=auto'

# --- directory jumps ---
alias dc='cd ~/.config'
alias dl='cd ~/Downloads'
alias dt='cd ~/Desktop'
alias ws='cd ~/Workspace'
alias docs='cd ~/Documents'
alias ds='cd ~/git/ds/'
alias dv='cd ~/vaults/HSD_VAULT/'

# --- resume the hdg Claude session ---
alias hdg-chat='cd ~ && claude --resume 2de51129-8146-457d-9bb4-b89216aab85a'

# --- functions ---
# make a directory (and parents) then cd into it
mkcd() {
  mkdir -p -- "$1" && cd -P -- "$1"
}

# universal archive extractor
extract() {
  if [ -f "$1" ]; then
    case "$1" in
    *.tar.bz2) tar xvjf "$1" ;;
    *.tar.gz) tar xvzf "$1" ;;
    *.bz2) bunzip2 "$1" ;;
    *.rar) unrar x "$1" ;;
    *.gz) gunzip "$1" ;;
    *.tar) tar xvf "$1" ;;
    *.tbz2) tar xvjf "$1" ;;
    *.tgz) tar xvzf "$1" ;;
    *.zip) unzip "$1" ;;
    *.Z) uncompress "$1" ;;
    *) echo "'$1' cannot be extracted via extract()" ;;
    esac
  else
    echo "'$1' is not a valid file"
  fi
}
